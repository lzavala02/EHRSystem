APP_NAME=EHRSystem API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql://ehr:ehr@db:5432/ehrsystem
REDIS_URL=redis://redis:6379/0
WORKER_QUEUE_NAME=ehr-default
APP_SECRET_KEY=replace-with-long-random-secret
# Optional file-based secret (takes precedence over APP_SECRET_KEY)
# APP_SECRET_KEY_FILE=/run/secrets/app_secret_key
POSTGRES_DB=ehrsystem
POSTGRES_USER=ehr
POSTGRES_PASSWORD=ehr
