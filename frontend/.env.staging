# Staging environment config

VITE_API_URL=https://staging-api.example.com/api
VITE_API_TIMEOUT=30000
VITE_AUTH_REDIRECT_URI=https://staging.example.com/auth/callback

VITE_ENABLE_2FA=true
VITE_ENABLE_AUDIT_LOG=true

VITE_JOB_POLL_INTERVAL_MS=2000
VITE_DASHBOARD_CACHE_TTL_MS=30000

VITE_LOG_LEVEL=info
VITE_HIPAA_AUDIT_ENABLED=true
